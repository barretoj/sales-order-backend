{
    "compilerOptions": {
        "isolatedModules": true,
        "target": "ES2024",
        "module": "Node16",
        "moduleResolution": "node16",
        "strict": true,
        "strictNullChecks": true,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "rootDir": "./"
    },
    "include": ["srv", "test"],
    "exclude": ["node_modules"]
}